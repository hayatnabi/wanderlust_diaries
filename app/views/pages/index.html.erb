<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wanderlust Diaries</title>
    <%# <link rel="stylesheet" href="application.css"> %>
    <style>
      /* General Reset */
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: 'Arial', sans-serif;
        line-height: 1.6;
        color: #333;
        background-color: #f5fffa;
      }

      /* Header */
      header {
        background-color: #008080;
        color: white;
        padding: 15px 0;
        position: fixed;
        width: 100%;
        top: 0;
        z-index: 1000;
      }

      .container {
        width: 90%;
        margin: auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      header h1 {
        font-size: 24px;
      }

      nav ul {
        display: flex;
        list-style: none;
      }

      nav ul li {
        margin-left: 20px;
      }

      nav ul li a {
        color: white;
        text-decoration: none;
        font-weight: bold;
      }

      nav ul li a:hover {
        text-decoration: underline;
      }

      .hamburger {
        display: none;
        font-size: 28px;
        cursor: pointer;
      }

      /* Hero Section */
      .hero {
        background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)), url('https://www.pixelstalk.net/wp-content/uploads/images6/Travel-HD-Wallpaper-Free-download.jpg') no-repeat center center/cover;
        color: white;
        text-align: center;
        padding: 150px 20px 100px;
        margin-top: 0px;
      }

      @keyframes fadeInUp {
        0% {
          opacity: 0;
          transform: translateY(-50px);
        }
        100% {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .hero h2 {
        font-size: 48px;
        margin-bottom: 20px;

        opacity: 0;
        transform: translateY(-50px);
        animation: fadeInUp 0.5s ease-out forwards;
      }

      .animation {
        opacity: 0;
        transform: translateY(-50px);
        animation: fadeInUp 0.5s ease-out forwards;
      }

      .hero p {
        font-size: 20px;
        margin-bottom: 30px;
      }

      .btn {
        background-color: #20b2aa;
        padding: 10px 20px;
        color: white;
        text-decoration: none;
        font-weight: bold;
        border-radius: 5px;
      }

      .btn:hover {
        background-color: #178f89;
      }

      /* Featured Destinations */
      .featured-destinations {
        padding: 50px 20px;
        text-align: center;
      }

      .destinations {
        display: flex;
        justify-content: space-between;
        margin-top: 30px;
        flex-wrap: wrap;
      }

      .card {
        background: white;
        padding: 20px;
        margin: 10px;
        flex: 1 1 30%;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        border-radius: 10px;
      }

      .card h3 {
        margin-bottom: 10px;
      }

      /* Travel Tips */
      .travel-tips {
        background: #f0f8ff;
        padding: 50px 20px;
        text-align: center
      }

      .travel-tips ul {
        list-style-type: disc;
        margin-left: 20px;
        margin-top: 20px;
        display: inline-block; /* THIS centers the list block */
        text-align: left; /* Keep list items aligned nicely inside */
      }

      /* Subscribe Section */
      .subscribe {
        padding: 50px 20px;
        text-align: center;
      }

      .subscribe form {
        margin-top: 20px;
      }

      .subscribe input[type="text"],
      .subscribe input[type="email"] {
        padding: 10px;
        margin: 5px;
        width: 200px;
        border: 1px solid #ccc;
        border-radius: 5px;
      }

      .subscribe button {
        padding: 10px 20px;
        background-color: #20b2aa;
        color: white;
        border: none;
        border-radius: 5px;
        font-weight: bold;
      }

      .subscribe button:hover {
        background-color: #178f89;
      }

      /* Footer */
      footer {
        background-color: #008080;
        color: white;
        text-align: center;
        padding: 15px 0;
        margin-top: 30px;
      }

      .socials a {
        color: white;
        margin: 0 5px;
        text-decoration: none;
      }

      .socials a:hover {
        text-decoration: underline;
      }

      /* Responsive */
      @media (max-width: 768px) {
        .hamburger {
          display: block;
        }

        nav ul {
          display: none;
          flex-direction: column;
          background-color: #008080;
          position: absolute;
          top: 60px;
          right: 20px;
          width: 200px;
          border-radius: 5px;
          padding: 10px 0;
        }

        nav ul.show {
          display: flex;
        }

        nav ul li {
          margin: 10px 0;
          text-align: center;
        }

        .destinations {
          flex-direction: column;
        }

        .card {
          flex: 1 1 100%;
        }

        .hero h2 {
          font-size: 32px;
        }

        .hero p {
          font-size: 16px;
        }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="container">
        <h1 class="animation">Wanderlust Diaries</h1>
        <nav>
          <div class="hamburger" id="hamburger">
            ☰
          </div>
          <ul id="nav-links">
            <li><a href="#">Home</a></li>
            <li><a href="#">Destinations</a></li>
            <li><a href="#">Travel Tips</a></li>
            <li><a href="#">Gallery</a></li>
            <li><a href="#">Subscribe</a></li>
          </ul>
        </nav>
      </div>
    </header>
    <section class="hero">
      <h2>Explore the World with Me</h2>
      <p>Join me on a journey across the globe — adventure awaits in every corner!</p>
      <a href="#" class="btn">Start Reading</a>
    </section>
    <section class="featured-destinations">
      <h2>Featured Destinations</h2>
      <div class="destinations">
        <div class="card">
          <h3>Paris, France</h3>
          <p>The city of lights, love, and unforgettable experiences.</p>
        </div>
        <div class="card">
          <h3>Kyoto, Japan</h3>
          <p>Ancient temples and cherry blossoms await your discovery.</p>
        </div>
        <div class="card">
          <h3>Cape Town, South Africa</h3>
          <p>Where mountains meet the sea and adventures never end.</p>
        </div>
      </div>
    </section>
    <section class="travel-tips">
      <h2>Travel Tips</h2>
      <ul>
        <li>Packing Hacks: Travel lighter and smarter.</li>
        <li>Budget Travel: See the world without breaking the bank.</li>
        <li>Local Etiquette: Respect cultures wherever you roam.</li>
      </ul>
    </section>
    <section class="subscribe">
      <h2>Subscribe to Our Newsletter</h2>
      <form>
        <input type="text" placeholder="Your Name" required>
        <input type="email" placeholder="Your Email" required>
        <button type="submit">Subscribe</button>
      </form>
    </section>
    <footer>
      <p>© 2025 Wanderlust Diaries</p>
      <div class="socials">
        <a href="#">Facebook</a> |
        <a href="#">Instagram</a> |
        <a href="#">Twitter</a>
      </div>
    </footer>
    <!-- Embedded JavaScript -->
    <script>
      const hamburger = document.getElementById('hamburger');
      const navLinks = document.getElementById('nav-links');

      hamburger.addEventListener('click', () => {
        navLinks.classList.toggle('show');
      });
    </script>
  </body>
</html>
